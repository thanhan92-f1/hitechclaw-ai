{
  "name": "hitechclawcontrol",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/channels/*"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "author": "Nguyen Thanh An by Pho Tue SoftWare Solutions JSC",
  "homepage": "https://github.com/thanhan92-f1/hitechclaw-ai#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thanhan92-f1/hitechclaw-ai.git"
  },
  "bugs": {
    "url": "https://github.com/thanhan92-f1/hitechclaw-ai/issues"
  },
  "scripts": {
    "dev": "next dev",
    "dev:up": "pwsh -ExecutionPolicy Bypass -File ./scripts/dev-up.ps1",
    "dev:down": "pwsh -ExecutionPolicy Bypass -File ./scripts/dev-down.ps1",
    "dev:reset": "pwsh -ExecutionPolicy Bypass -File ./scripts/dev-up.ps1 -Reset",
    "dev:clean": "pwsh -ExecutionPolicy Bypass -File ./scripts/dev-clean.ps1",
    "clean:all": "pwsh -ExecutionPolicy Bypass -File ./scripts/clean-all.ps1",
    "dev:db:up": "docker compose -f docker-compose.dev.yml --env-file .env.local up -d",
    "dev:db:down": "docker compose -f docker-compose.dev.yml --env-file .env.local down",
    "dev:db:logs": "docker compose -f docker-compose.dev.yml --env-file .env.local logs -f db",
    "dev:db:reset": "docker compose -f docker-compose.dev.yml --env-file .env.local down -v && docker compose -f docker-compose.dev.yml --env-file .env.local up -d",
    "dev:setup": "npm run dev:db:up && npm run db:migrate:dev",
    "dev:test:app": "node --env-file=.env.test.local ./node_modules/next/dist/bin/next dev -p 3001",
    "build": "next build",
    "build:shared": "npm --prefix ./packages/shared run build",
    "build:db": "npm --prefix ./packages/db run build",
    "build:cli": "npm --prefix ./packages/cli run build",
    "build:core": "npm --prefix ./packages/core run build",
    "build:chat-sdk": "npm --prefix ./packages/chat-sdk run build",
    "build:doc-mcp": "npm --prefix ./packages/doc-mcp run build",
    "build:domains": "npm --prefix ./packages/domains run build",
    "build:integrations": "npm --prefix ./packages/integrations run build",
    "build:ml": "npm --prefix ./packages/ml run build",
    "build:skill-hub": "npm --prefix ./packages/skill-hub run build",
    "build:skills": "npm --prefix ./packages/skills run build",
    "build:sandbox": "npm --prefix ./packages/sandbox run build",
    "build:gateway": "npm --prefix ./packages/gateway run build",
    "build:server": "npm --prefix ./packages/server run build",
    "build:sdk": "npm --prefix ./packages/sdk run build",
    "build:web": "npm --prefix ./packages/web run build",
    "build:zalo-miniapp": "npm --prefix ./packages/zalo-miniapp run build",
    "build:channel:discord": "npm --prefix ./packages/channels/discord run build",
    "build:channel:facebook": "npm --prefix ./packages/channels/facebook run build",
    "build:channel:msteams": "npm --prefix ./packages/channels/msteams run build",
    "build:channel:slack": "npm --prefix ./packages/channels/slack run build",
    "build:channel:telegram": "npm --prefix ./packages/channels/telegram run build",
    "build:channel:whatsapp": "npm --prefix ./packages/channels/whatsapp run build",
    "build:channel:zalo": "npm --prefix ./packages/channels/zalo run build",
    "build:channels": "npm run build:channel:discord && npm run build:channel:facebook && npm run build:channel:msteams && npm run build:channel:slack && npm run build:channel:telegram && npm run build:channel:whatsapp && npm run build:channel:zalo",
    "build:packages": "npm run build:shared && npm run build:core && npm run build:chat-sdk && npm run build:doc-mcp && npm run build:domains && npm run build:integrations && npm run build:ml && npm run build:skill-hub && npm run build:skills && npm run build:sandbox && npm run build:sdk",
    "build:workspace-packages": "npm run build:shared && npm run build:db && npm run build:cli && npm run build:core && npm run build:chat-sdk && npm run build:doc-mcp && npm run build:domains && npm run build:integrations && npm run build:ml && npm run build:skill-hub && npm run build:skills && npm run build:sandbox && npm run build:gateway && npm run build:channels && npm run build:server && npm run build:sdk",
    "pack:sdk": "npm pack ./packages/sdk",
    "test:sdk": "npm run build:sdk && node --test packages/sdk/tests/*.test.mjs",
    "smoke:sdk": "npm run build:sdk && node ./packages/sdk/tests/smoke.mjs",
    "check:sdk-version": "node ./scripts/check-sdk-version.mjs",
    "start": "next start",
    "lint": "eslint",
    "test:e2e": "playwright test",
    "test:e2e:managed": "playwright test",
    "test:e2e:local": "pwsh -ExecutionPolicy Bypass -File ./scripts/test-e2e-local.ps1",
    "test:e2e:api": "playwright test tests/api",
    "test:e2e:ui": "playwright test tests/ui",
    "test:e2e:mobile": "playwright test tests/mobile --project=chromium-mobile",
    "test:e2e:edge": "playwright test tests/edge",
    "test:e2e:setup": "playwright test tests/setup",
    "test:smoke": "playwright test --grep @smoke",
    "test:smoke:managed": "playwright test --grep @smoke",
    "test:smoke:local": "pwsh -ExecutionPolicy Bypass -File ./scripts/test-e2e-local.ps1 -- --grep @smoke",
    "test:db:up": "pwsh -ExecutionPolicy Bypass -File ./scripts/test-db-up.ps1",
    "test:db:down": "pwsh -ExecutionPolicy Bypass -File ./scripts/test-db-down.ps1",
    "test:db:reset": "pwsh -ExecutionPolicy Bypass -File ./scripts/test-db-up.ps1 -Reset",
    "test:clean": "pwsh -ExecutionPolicy Bypass -File ./scripts/test-clean.ps1",
    "test:setup": "npm run test:db:up && npm run db:migrate:test",
    "test:e2e:ci-local": "pwsh -ExecutionPolicy Bypass -File ./scripts/test-e2e-ci-local.ps1",
    "test:zalo": "tsx scripts/test-zalo-webhook-helpers.ts",
    "check:local": "pwsh -ExecutionPolicy Bypass -File ./scripts/check-local.ps1",
    "check:local:api": "pwsh -ExecutionPolicy Bypass -File ./scripts/check-local.ps1 -PlaywrightCommand test:e2e:api",
    "check:local:ui": "pwsh -ExecutionPolicy Bypass -File ./scripts/check-local.ps1 -PlaywrightCommand test:e2e:ui",
    "check:local:mobile": "pwsh -ExecutionPolicy Bypass -File ./scripts/check-local.ps1 -PlaywrightCommand test:e2e:mobile",
    "check:local:edge": "pwsh -ExecutionPolicy Bypass -File ./scripts/check-local.ps1 -PlaywrightCommand test:e2e:edge",
    "check:pre-push": "pwsh -ExecutionPolicy Bypass -File ./scripts/pre-push-check.ps1",
    "check:pre-push:api": "pwsh -ExecutionPolicy Bypass -File ./scripts/pre-push-check.ps1 -BaselineCommand check:local:api -VerificationCommand test:e2e:api",
    "check:pre-push:ui": "pwsh -ExecutionPolicy Bypass -File ./scripts/pre-push-check.ps1 -BaselineCommand check:local:ui -VerificationCommand test:e2e:ui",
    "check:pre-push:mobile": "pwsh -ExecutionPolicy Bypass -File ./scripts/pre-push-check.ps1 -BaselineCommand check:local:mobile -VerificationCommand test:e2e:mobile",
    "check:pre-push:edge": "pwsh -ExecutionPolicy Bypass -File ./scripts/pre-push-check.ps1 -BaselineCommand check:local:edge -VerificationCommand test:e2e:edge",
    "verify:ghcr": "pwsh -ExecutionPolicy Bypass -File ./scripts/verify-ghcr-image.ps1",
    "check:summary": "pwsh -ExecutionPolicy Bypass -File ./scripts/check-summary.ps1",
    "hooks:install": "pwsh -ExecutionPolicy Bypass -File ./scripts/install-git-hooks.ps1",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:migrate:dev": "node --env-file=.env.local ./node_modules/tsx/dist/cli.mjs scripts/migrate.ts",
    "db:migrate:test": "node --env-file=.env.test.local ./node_modules/tsx/dist/cli.mjs scripts/migrate.ts"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "bcryptjs": "^3.0.3",
    "cmdk": "^1.1.1",
    "dompurify": "^3.4.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "marked": "^17.0.6",
    "next": "^16.2.4",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "redis": "^5.12.1",
    "sonner": "^2.0.7",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wait-on": "^9.0.5"
  },
  "overrides": {
    "axios": "1.13.6",
    "lodash": "4.18.1"
  }
}
