{
  "name": "mission-control",
  "version": "0.1.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "author": "Nguyen Thanh An by Pho Tue SoftWare Solutions JSC",
  "homepage": "https://github.com/thanhan92-f1/hitechclaw-ai#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thanhan92-f1/hitechclaw-ai.git"
  },
  "bugs": {
    "url": "https://github.com/thanhan92-f1/hitechclaw-ai/issues"
  },
  "scripts": {
    "dev": "next dev",
    "dev:up": "pwsh -ExecutionPolicy Bypass -File ./scripts/dev-up.ps1",
    "dev:down": "pwsh -ExecutionPolicy Bypass -File ./scripts/dev-down.ps1",
    "dev:reset": "pwsh -ExecutionPolicy Bypass -File ./scripts/dev-up.ps1 -Reset",
    "dev:clean": "pwsh -ExecutionPolicy Bypass -File ./scripts/dev-clean.ps1",
    "clean:all": "pwsh -ExecutionPolicy Bypass -File ./scripts/clean-all.ps1",
    "dev:db:up": "docker compose -f docker-compose.dev.yml --env-file .env.local up -d",
    "dev:db:down": "docker compose -f docker-compose.dev.yml --env-file .env.local down",
    "dev:db:logs": "docker compose -f docker-compose.dev.yml --env-file .env.local logs -f db",
    "dev:db:reset": "docker compose -f docker-compose.dev.yml --env-file .env.local down -v && docker compose -f docker-compose.dev.yml --env-file .env.local up -d",
    "dev:setup": "npm run dev:db:up && npm run db:migrate:dev",
    "dev:test:app": "node --env-file=.env.test.local ./node_modules/next/dist/bin/next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:e2e": "playwright test",
    "test:e2e:managed": "playwright test",
    "test:e2e:local": "pwsh -ExecutionPolicy Bypass -File ./scripts/test-e2e-local.ps1",
    "test:smoke": "playwright test --grep @smoke",
    "test:smoke:managed": "playwright test --grep @smoke",
    "test:smoke:local": "pwsh -ExecutionPolicy Bypass -File ./scripts/test-e2e-local.ps1 -- --grep @smoke",
    "test:db:up": "pwsh -ExecutionPolicy Bypass -File ./scripts/test-db-up.ps1",
    "test:db:down": "pwsh -ExecutionPolicy Bypass -File ./scripts/test-db-down.ps1",
    "test:db:reset": "pwsh -ExecutionPolicy Bypass -File ./scripts/test-db-up.ps1 -Reset",
    "test:clean": "pwsh -ExecutionPolicy Bypass -File ./scripts/test-clean.ps1",
    "test:setup": "npm run test:db:up && npm run db:migrate:test",
    "test:e2e:ci-local": "pwsh -ExecutionPolicy Bypass -File ./scripts/test-e2e-ci-local.ps1",
    "test:zalo": "tsx scripts/test-zalo-webhook-helpers.ts",
    "check:local": "pwsh -ExecutionPolicy Bypass -File ./scripts/check-local.ps1",
    "check:pre-push": "pwsh -ExecutionPolicy Bypass -File ./scripts/pre-push-check.ps1",
    "check:summary": "pwsh -ExecutionPolicy Bypass -File ./scripts/check-summary.ps1",
    "hooks:install": "pwsh -ExecutionPolicy Bypass -File ./scripts/install-git-hooks.ps1",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:migrate:dev": "node --env-file=.env.local ./node_modules/tsx/dist/cli.mjs scripts/migrate.ts",
    "db:migrate:test": "node --env-file=.env.test.local ./node_modules/tsx/dist/cli.mjs scripts/migrate.ts"
  },
  "dependencies": {
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@xyflow/react": "^12.10.2",
    "bcryptjs": "^3.0.3",
    "cmdk": "^1.1.1",
    "dompurify": "^3.3.3",
    "elkjs": "^0.11.1",
    "framer-motion": "^12.38.0",
    "geist": "^1.7.0",
    "lucide-react": "^1.7.0",
    "marked": "^17.0.6",
    "next": "^16.2.2",
    "nodemailer": "^8.0.4",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  },
  "overrides": {
    "axios": "1.13.6",
    "lodash": "4.18.1"
  }
}
