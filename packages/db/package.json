{
    "name": "@hitechclaw/db",
    "version": "2.2.0",
    "description": "HiTechClaw database layer — Drizzle ORM + PostgreSQL",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./mongo": {
            "types": "./dist/mongo.d.ts",
            "import": "./dist/mongo.js"
        }
    },
    "scripts": {
        "build": "tsc -b && node -e \"const fs=require('node:fs');fs.cpSync('src/migrations','dist/migrations',{ recursive: true });\"",
        "dev": "tsc -b --watch",
        "generate": "npx drizzle-kit@0.31.10 generate",
        "migrate": "tsx src/migrate.ts",
        "studio": "npx drizzle-kit@0.31.10 studio"
    },
    "dependencies": {
        "@hitechclaw/shared": "*",
        "dotenv": "^16.4.0",
        "drizzle-orm": "^0.45.2",
        "mongodb": "^7.2.0",
        "postgres": "^3.4.0"
    },
    "devDependencies": {
        "tsx": "^4.19.0"
    }
}