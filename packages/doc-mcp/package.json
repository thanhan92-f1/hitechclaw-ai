{
    "name": "@hitechclaw/doc-mcp",
    "version": "1.0.0",
    "description": "HiTechClaw Dev Docs MCP Server — Developer documentation knowledge base accessible via MCP for AI-assisted coding",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "bin": {
        "hitechclaw-doc-mcp": "./dist/bin.js"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "start": "node dist/bin.js",
        "mcp": "node dist/bin.js"
    },
    "keywords": [
        "hitechclaw",
        "mcp",
        "documentation",
        "knowledge-base",
        "developer-docs"
    ],
    "author": "xDev Asia <dev@xdev.asia>",
    "license": "MIT",
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.12.1",
        "zod": "^3.23.0"
    },
    "devDependencies": {
        "typescript": "^5.8.0"
    }
}