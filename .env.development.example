# HiTechClaw AI local development environment
# Copy to .env.local for host-based development.
# Example (PowerShell): Copy-Item .env.development.example .env.local

# ── Database ──────────────────────────────────────────────────────────────
POSTGRES_USER=hitechclaw-ai
POSTGRES_PASSWORD=hitechclaw-ai
POSTGRES_DB=hitechclaw-ai
DB_PORT=5432
DATABASE_URL=postgresql://hitechclaw-ai:hitechclaw-ai@127.0.0.1:5432/hitechclaw-ai

# ── Authentication ────────────────────────────────────────────────────────
MC_ADMIN_TOKEN=dev-admin-token-change-me
MC_AGENT_TOKENS=default:dev-agent-token-change-me
NEXTAUTH_SECRET=dev-nextauth-secret-change-me
NEXTAUTH_URL=http://localhost:3000
OPENCLAW_DEFAULT_NAME=Local OpenClaw
OPENCLAW_DEFAULT_PROVIDER=anthropic
OPENCLAW_DEFAULT_MODEL=anthropic/claude-sonnet-4-20250514
OPENCLAW_MGMT_BASE_URL=http://localhost:9998
OPENCLAW_GATEWAY_URL=http://localhost:18789
# OPENCLAW_MGMT_API_KEY=dev-openclaw-management-key

# ── Application ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HITECHCLAW_AI_BASE_URL=http://localhost:3000
MC_GATEWAY_URL=http://localhost:3000

# ── Optional local dev toggles ────────────────────────────────────────────
# CRON_SECRET=dev-cron-secret
# MC_PROVISIONING_TOKEN=dev-provisioning-token
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_EMAIL=admin@localhost

# ── Optional SMTP relay for local email alert testing ────────────────────
# SMTP_HOST=127.0.0.1
# SMTP_PORT=1025
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="HiTechClaw AI Dev <dev-alerts@localhost>"
# SMTP_REPLY_TO=dev-alerts@localhost
