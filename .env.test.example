# HiTechClaw AI local test environment
# Copy to .env.test.local for isolated Playwright / local integration tests.

# ── Database ──────────────────────────────────────────────────────────────
POSTGRES_USER=hitechclaw-ai
POSTGRES_PASSWORD=hitechclaw-ai
POSTGRES_DB=hitechclaw-ai_test
DB_PORT=55432
DATABASE_URL=postgresql://hitechclaw-ai:hitechclaw-ai@127.0.0.1:55432/hitechclaw-ai_test

# ── Authentication ────────────────────────────────────────────────────────
MC_ADMIN_TOKEN=test-admin-token
MC_AGENT_TOKENS=default:test-agent-token
NEXTAUTH_SECRET=test-nextauth-secret
NEXTAUTH_URL=http://localhost:3001
OPENCLAW_DEFAULT_NAME=Test OpenClaw
OPENCLAW_DEFAULT_PROVIDER=anthropic
OPENCLAW_DEFAULT_MODEL=anthropic/claude-sonnet-4-20250514
OPENCLAW_MGMT_BASE_URL=http://127.0.0.1:9998
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
# OPENCLAW_MGMT_API_KEY=test-openclaw-management-key

# ── Application ───────────────────────────────────────────────────────────
NODE_ENV=test
PORT=3001
HITECHCLAW_AI_BASE_URL=http://localhost:3001
MC_GATEWAY_URL=http://localhost:3001

# Optional SMTP relay for test email notifications
# SMTP_HOST=127.0.0.1
# SMTP_PORT=1025
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="HiTechClaw AI Test <test-alerts@localhost>"
